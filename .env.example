# =============================================================================
# DATABASE
# =============================================================================
# Neon or Supabase PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/portfolio?sslmode=require"
# Direct connection URL (for Prisma migrations - bypasses connection pooling)
DIRECT_URL="postgresql://user:password@host:5432/portfolio?sslmode=require"

# =============================================================================
# AUTHENTICATION (NextAuth v5)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
# The canonical URL of your site (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (add as needed)
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# Admin credentials for credential-based login
ADMIN_EMAIL="admin@example.com"
# Generate with: openssl rand -base64 32 then hash with bcrypt
ADMIN_PASSWORD_HASH="$2b$10$..."

# =============================================================================
# FILE STORAGE (Vercel Blob)
# =============================================================================
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# =============================================================================
# EMAIL (Nodemailer)
# =============================================================================
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
CONTACT_EMAIL_TO="rupak@example.com"
CONTACT_EMAIL_FROM="noreply@yoursite.com"

# =============================================================================
# RATE LIMITING (Upstash Redis) - optional, falls back to in-memory
# =============================================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# ANALYTICS (optional)
# =============================================================================
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=""

# =============================================================================
# SITE METADATA
# =============================================================================
NEXT_PUBLIC_SITE_URL="https://rupakghosh.com"
NEXT_PUBLIC_SITE_NAME="Rupak Ghosh"
